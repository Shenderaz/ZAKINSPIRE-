# Firebase web app configuration.
# Copy this file to `.env` and fill in values from:
#   Firebase console -> Project settings -> Your apps -> Web app -> Config
#
# NOTE: these values are embedded in the browser bundle and are not secret.
# The `.env` file is gitignored to keep source clean, not to hide credentials.
# Real security comes from Firestore rules + Authentication -> Authorized domains.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
